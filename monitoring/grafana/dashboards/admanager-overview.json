{
  "title": "Active Directory Manager",
  "schemaVersion": 39,
  "version": 8,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Uptime",
      "targets": [
        {
          "expr": "admanager_uptime_seconds"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Requests",
      "targets": [
        {
          "expr": "sum(rate(admanager_http_requests_total[5m])) by (status)"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      }
    },
    {
      "type": "timeseries",
      "title": "Application Events",
      "targets": [
        {
          "expr": "sum(rate(admanager_events_total[5m])) by (event)"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      }
    },
    {
      "type": "stat",
      "title": "Worker Uptime",
      "targets": [
        {
          "expr": "admanager_worker_uptime_seconds"
        }
      ],
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Worker Jobs",
      "targets": [
        {
          "expr": "increase(admanager_worker_jobs_total[15m])"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      }
    },
    {
      "type": "timeseries",
      "title": "Target Availability",
      "targets": [
        {
          "expr": "up{job=~\"admanager-.*\"}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      }
    },
    {
      "type": "table",
      "title": "AD Inventory",
      "targets": [
        {
          "expr": "admanager_inventory_objects",
          "format": "table",
          "instant": true,
          "legendFormat": "{{object_type}} / {{status}}"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "description": "Contagem de objetos do Active Directory por tipo e status.",
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "countRows": false,
          "fields": ""
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "object_type"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Tipo"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "users": {
                        "text": "Usuários"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "groups": {
                        "text": "Grupos"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "computers": {
                        "text": "Computadores"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "status"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Status"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "all": {
                        "text": "Todos"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "active": {
                        "text": "Ativos"
                      }
                    }
                  },
                  {
                    "type": "value",
                    "options": {
                      "disabled": {
                        "text": "Desabilitados"
                      }
                    }
