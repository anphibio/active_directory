APP_ENV=development
APP_PORT=8080
APP_BASE_URL=http://localhost:8080

API_HOST=0.0.0.0
API_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:4173,http://127.0.0.1:4173
TRUSTED_PROXY_CIDRS=
FRONTEND_PORT=3000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
ALERTMANAGER_PORT=9093
ALERTMANAGER_RESOLVE_TIMEOUT=5m
ALERTMANAGER_GROUP_WAIT=30s
ALERTMANAGER_GROUP_INTERVAL=5m
ALERTMANAGER_REPEAT_INTERVAL=4h
ALERTMANAGER_CRITICAL_REPEAT_INTERVAL=1h
ALERTMANAGER_WEBHOOK_ENABLED=false
ALERTMANAGER_WEBHOOK_URL=
ALERTMANAGER_WEBHOOK_SEND_RESOLVED=true
ALERTMANAGER_SMTP_ENABLED=false
ALERTMANAGER_SMTP_SMARTHOST=smtp.example.local:587
ALERTMANAGER_SMTP_FROM=admanager@example.local
ALERTMANAGER_SMTP_TO=infra@example.local
ALERTMANAGER_SMTP_AUTH_USERNAME=
ALERTMANAGER_SMTP_AUTH_PASSWORD=
ALERTMANAGER_SMTP_AUTH_IDENTITY=
ALERTMANAGER_SMTP_REQUIRE_TLS=true
ALERTMANAGER_EMAIL_SEND_RESOLVED=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

AD_DOMAIN=corp.example.local
AD_BASE_DN=DC=corp,DC=example,DC=local
AD_DEFAULT_USER_OU=OU=Users,DC=corp,DC=example,DC=local
AD_DEFAULT_GROUP_OU=OU=Groups,DC=corp,DC=example,DC=local
AD_DEFAULT_COMPUTER_OU=OU=Computers,DC=corp,DC=example,DC=local
AD_SERVER=ldaps://dc01.corp.example.local:636
AD_BIND_DN=CN=svc-ad-manager,OU=Service Accounts,DC=corp,DC=example,DC=local
AD_BIND_PASSWORD=change-me
AD_LOGIN_DOMAIN=corp.example.local
AD_ROLE_ADMIN_GROUP_DN=CN=ADManager-Administradores,OU=Groups,DC=corp,DC=example,DC=local
AD_ROLE_OPERATOR_GROUP_DN=CN=ADManager-Operadores,OU=Groups,DC=corp,DC=example,DC=local
AD_ROLE_VIEWER_GROUP_DN=CN=ADManager-Leitores,OU=Groups,DC=corp,DC=example,DC=local
AD_ROLE_AUDITOR_GROUP_DN=CN=ADManager-Auditores,OU=Groups,DC=corp,DC=example,DC=local
AD_SEARCH_TIMEOUT_SECONDS=30
AD_USE_LDAPS=true
AD_TLS_REQUIRE_CERT=true
AD_CA_CERT_PATH=/run/secrets/ad_ca_cert
ALLOW_INSECURE_LDAP_IN_PRODUCTION=false
REQUIRE_LDAPS_FOR_WRITES=true

POSTGRES_DB=admanager
POSTGRES_USER=admanager
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://admanager:change-me@database:5432/admanager
REDIS_URL=redis://redis:6379/0

JWT_SECRET=change-me
SESSION_SECRET=change-me
ENCRYPTION_KEY=change-me
APP_BOOTSTRAP_ADMIN_TOKEN=change-me
WORKSTATION_STATUS_ENABLED=true
WORKSTATION_STATUS_TOKEN=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=480
PROTECTED_GROUP_PATTERNS=Domain Admins,Enterprise Admins,Schema Admins,Administrators,Account Operators,Server Operators,Backup Operators

REPORT_OUTPUT_DIR=/app/reports
REPORT_RETENTION_DAYS=90

AUDIT_LOG_LEVEL=info
AUDIT_DATABASE_ENABLED=true
AUDIT_RETENTION_DAYS=365
WORKER_AUDIT_RETENTION_ENABLED=true
WORKSTATION_STATUS_RETENTION_DAYS=90
WORKER_WORKSTATION_STATUS_RETENTION_ENABLED=true
WORKER_WORKSTATION_STATUS_RETENTION_INTERVAL_SECONDS=86400
LOG_FORMAT=json

WORKER_HEARTBEAT_SECONDS=60
WORKER_API_BASE_URL=http://api:8080
WORKER_API_SUBJECT=admanager-worker
WORKER_API_TIMEOUT_SECONDS=30
WORKER_API_TOKEN_MODE=local
WORKER_API_TOKEN_EXPIRE_SECONDS=3600
WORKER_METRICS_ENABLED=true
WORKER_METRICS_LISTEN_PORT=9100
WORKER_METRICS_PORT=9100
WORKER_SCHEDULER_INTERVAL_SECONDS=30
WORKER_REPORT_CLEANUP_ENABLED=true
WORKER_INVENTORY_SNAPSHOT_ENABLED=true
WORKER_INVENTORY_SNAPSHOT_INTERVAL_SECONDS=86400
WORKER_INVENTORY_QUERY_LIMIT=500
WORKER_INVENTORY_INACTIVE_DAYS=90
WORKER_INVENTORY_MACHINE_PASSWORD_DAYS=90
WORKER_INVENTORY_USER_OUS=
WORKER_INVENTORY_GROUP_OUS=
WORKER_INVENTORY_COMPUTER_OUS=
